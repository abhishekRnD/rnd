<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Calculator Hub | Beam Infotech</title>
  <link rel="stylesheet" href="main.css" />
</head>
<body>
  <div class="container">
    <h1>Calculator Hub</h1>

    <input
      type="text"
      id="searchInput"
      class="search-bar"
      placeholder="Search calculators..."
      aria-label="Search calculators"
      tabindex="1"
    />

    <div class="grid">
      <!-- REAL CALCULATORS -->
      <div class="calculator" data-name="voltage divider calculator">
        <div class="image-placeholder"><img src="voltage_divider_schematic.png" alt="Voltage Divider Image" />
</div>
        <div class="description">
          Calculate output voltage using two resistors in a voltage divider circuit.
        </div>
        <a href="voltage-divider/index.html" class="calc-btn">Voltage Divider</a>
      </div>

      <div class="calculator" data-name="resistor color code calculator">
        <div class="image-placeholder">Image space</div>
        <div class="description">
          Decode resistor color bands to determine resistance, tolerance, and value.
        </div>
        <a href="resistor-color-code/index.html" class="calc-btn">Resistor Color Code</a>
      </div>
      
      <div class="calculator" data-name="opamp gain calculator">
        <div class="image-placeholder">Image space</div>
        <div class="description">
          Calculate gain and output voltage for inverting or non-inverting op-amp circuits.
        </div>
        <a href="opamp-gain/index.html" class="calc-btn">Op-Amp Gain</a>
      </div>

      <!-- PLACEHOLDER CALCULATORS (4 to 20) -->
      <!-- You can update these as you build them -->
      <div class="calculator" data-name="calculator 4">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 4</div>
        <a href="#" class="calc-btn">Calculator 4</a>
      </div>

      <div class="calculator" data-name="calculator 5">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 5</div>
        <a href="#" class="calc-btn">Calculator 5</a>
      </div>

      <div class="calculator" data-name="calculator 6">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 6</div>
        <a href="#" class="calc-btn">Calculator 6</a>
      </div>

      <div class="calculator" data-name="calculator 7">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 7</div>
        <a href="#" class="calc-btn">Calculator 7</a>
      </div>

      <div class="calculator" data-name="calculator 8">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 8</div>
        <a href="#" class="calc-btn">Calculator 8</a>
      </div>

      <div class="calculator" data-name="calculator 9">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 9</div>
        <a href="#" class="calc-btn">Calculator 9</a>
      </div>

      <div class="calculator" data-name="calculator 10">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 10</div>
        <a href="#" class="calc-btn">Calculator 10</a>
      </div>

      <div class="calculator" data-name="calculator 11">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 11</div>
        <a href="#" class="calc-btn">Calculator 11</a>
      </div>

      <div class="calculator" data-name="calculator 12">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 12</div>
        <a href="#" class="calc-btn">Calculator 12</a>
      </div>

      <div class="calculator" data-name="calculator 13">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 13</div>
        <a href="#" class="calc-btn">Calculator 13</a>
      </div>

      <div class="calculator" data-name="calculator 14">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 14</div>
        <a href="#" class="calc-btn">Calculator 14</a>
      </div>

      <div class="calculator" data-name="calculator 15">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 15</div>
        <a href="#" class="calc-btn">Calculator 15</a>
      </div>

      <div class="calculator" data-name="calculator 16">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 16</div>
        <a href="#" class="calc-btn">Calculator 16</a>
      </div>

      <div class="calculator" data-name="calculator 17">
        <div class="image-placeholder">Image space</div>
        <div class="description">Description for Calculator 17</div>
        <a href="#" class="calc-btn">Calculator 17</a>
      </div>

      <div class="calculator" data-name="calculator 18">
